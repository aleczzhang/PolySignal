# Copy this file to .env and fill in the values
# cp .env.example .env

# Polymarket (no key needed — public API)
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# Kalshi — uses RSA key-pair auth (not a simple Bearer token)
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=your_kalshi_key_id_here
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# K2 Think V2 — get the key from the team
K2_THINK_BASE_URL=https://api.k2think.ai/v1
K2_THINK_API_KEY=your_k2_api_key_here
K2_MODEL=MBZUAI-IFM/K2-Think-v2

PORT=3001
